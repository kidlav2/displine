rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -- Helper functions ---------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(challengeId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/challenges/$(challengeId)/participants/$(request.auth.uid))
          .data.role == "owner";
    }

    function isOrganizer(challengeId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/challenges/$(challengeId)/participants/$(request.auth.uid))
          .data.isAdmin == true;
    }

    function isParticipant(challengeId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/challenges/$(challengeId)/participants/$(request.auth.uid));
    }

    // -- Invite codes (public) ---------------------------------------------

    match /invites/{code} {
      allow read: if true;
      allow create: if isSignedIn() &&
        exists(/databases/$(database)/documents/challenges/$(request.resource.data.challengeId)) &&
        get(/databases/$(database)/documents/challenges/$(request.resource.data.challengeId))
          .data.ownerUid == request.auth.uid;
      allow update: if isSignedIn() &&
        resource.data.usedAt == null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["usedAt"]) &&
        request.resource.data.usedAt != null;
    }

    // -- User profiles ------------------------------------------------------

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // Strava tokens -- server-only via Admin SDK, never accessible from client.
    match /users/{userId}/integrations/{integration} {
      allow read, write: if false;
    }

    // -- Challenges ---------------------------------------------------------

    match /challenges/{challengeId} {
      allow read:   if isParticipant(challengeId);
      allow create: if isSignedIn();
      allow update: if isOrganizer(challengeId);
      allow delete: if isOwner(challengeId);

      match /participants/{uid} {
        allow read:  if isParticipant(challengeId);

        // Self-service: a participant may edit ONLY presentation fields on their
        // own doc (name/avatar/timezone). Never role, isAdmin, lives, km,
        // results, penalties, or active — those are organizer-controlled.
        allow update: if isSignedIn() && request.auth.uid == uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["tz", "photoUrl", "name", "ini"]);

        // Organizer: may adjust gameplay fields (lives, active, penalties, km,
        // results). Changing role/isAdmin requires an OWNER acting on a DIFFERENT
        // participant — no self-elevation, and helpers cannot promote at all.
        allow update: if isOrganizer(challengeId) && (
          (request.resource.data.role == resource.data.role &&
           request.resource.data.isAdmin == resource.data.isAdmin) ||
          (isOwner(challengeId) && request.auth.uid != uid)
        );

        allow delete: if isOrganizer(challengeId);

        allow create: if isSignedIn() && request.auth.uid == uid && (
          (
            get(/databases/$(database)/documents/challenges/$(challengeId))
              .data.ownerUid == request.auth.uid &&
            request.resource.data.role == "owner" &&
            request.resource.data.isAdmin == true &&
            request.resource.data.km == 0 &&
            request.resource.data.results.size() == 0 &&
            request.resource.data.penalties.size() == 0
          ) ||
          (
            request.resource.data.role == "participant" &&
            request.resource.data.isAdmin == false &&
            request.resource.data.km == 0 &&
            request.resource.data.active == true &&
            request.resource.data.results.size() == 0 &&
            request.resource.data.penalties.size() == 0 &&
            request.resource.data.lives ==
              get(/databases/$(database)/documents/challenges/$(challengeId))
                .data.settings.startingLives
          ) ||
          (
            request.resource.data.isAdmin == true &&
            request.resource.data.km == 0 &&
            request.resource.data.active == true &&
            request.resource.data.results.size() == 0 &&
            request.resource.data.penalties.size() == 0 &&
            request.resource.data.role in ["helper", "owner"] &&
            "inviteCode" in request.resource.data &&
            get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode))
              .data.type == "team" &&
            get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode))
              .data.challengeId == challengeId &&
            get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode))
              .data.role == request.resource.data.role &&
            get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode))
              .data.usedAt == null
          )
        );
      }

      match /feed/{postId} {
        allow read:   if isParticipant(challengeId);
        // Author cannot be spoofed: participantId must be the caller, isAdmin must
        // match the caller's real participant doc, and only organizers may write
        // "system:*" event posts (the UI renders those as authoritative actions).
        allow create: if isParticipant(challengeId) &&
          request.resource.data.participantId == request.auth.uid &&
          request.resource.data.isAdmin == isOrganizer(challengeId) &&
          (isOrganizer(challengeId) ||
           !request.resource.data.type.matches('system:.*'));
        allow update: if isOrganizer(challengeId) ||
          (isParticipant(challengeId) &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(["likes", "socialComments"])) ||
          (isParticipant(challengeId) &&
           resource.data.participantId == request.auth.uid &&
           resource.data.submissionStatus == "pending");
        allow delete: if isOrganizer(challengeId);
      }

      match /submissions/{submissionId} {
        allow read: if isOrganizer(challengeId) ||
          (resource == null && isParticipant(challengeId)) ||
          (resource != null && resource.data.participantUid == request.auth.uid);
        allow create: if isParticipant(challengeId) &&
          request.resource.data.participantUid == request.auth.uid;
        allow update: if isOrganizer(challengeId) ||
          (isParticipant(challengeId) &&
           request.auth.uid == resource.data.participantUid &&
           (
             // Submitting proof (after check-in) or resubmitting after a rejection:
             // the participant legitimately sets km/isLate/photo/text here.
             (resource.data.status in ["checked_in", "rejected"] &&
              request.resource.data.status in ["checked_in", "pending"]) ||
             // Already pending: may only touch non-scoring fields. Prevents
             // inflating km or flipping isLate/scoreKey/type before review.
             (resource.data.status == "pending" &&
              request.resource.data.status == "pending" &&
              request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(["text", "photoUrl", "submittedAt", "status"]))
           ));
        allow delete: if isOwner(challengeId);
      }

      match /penalties/{penaltyId} {
        allow read: if isOrganizer(challengeId) ||
          resource.data.participantUid == request.auth.uid;
        allow create, update: if isOrganizer(challengeId);
        allow delete: if isOwner(challengeId);
      }

      match /achievements/{achievementId} {
        allow read:  if isParticipant(challengeId);
        allow write: if isOrganizer(challengeId);
      }

      match /team/{memberId} {
        allow read:  if isOrganizer(challengeId);
        allow write: if isOwner(challengeId);
      }

      match /tasks/{taskId} {
        allow read:  if isParticipant(challengeId);
        allow write: if isOrganizer(challengeId);
      }

      match /taskTemplates/{templateId} {
        allow read:  if isParticipant(challengeId);
        allow write: if isOrganizer(challengeId);
      }

      match /orgNotes/{participantUid} {
        allow read, write: if isOrganizer(challengeId);
      }

      match /postponements/{postponementId} {
        allow read: if isOrganizer(challengeId) ||
          (resource == null && isParticipant(challengeId)) ||
          (resource != null && isParticipant(challengeId) &&
           resource.data.participantUid == request.auth.uid);
        allow create: if isParticipant(challengeId) &&
          request.resource.data.participantUid == request.auth.uid &&
          request.resource.data.status == "pending";
        allow update: if isOrganizer(challengeId) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["status", "organizerNote", "resolvedAt"]);
      }
    }
  }
}
