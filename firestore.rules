rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(challengeId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/challenges/$(challengeId)/participants/$(request.auth.uid))
          .data.role == "owner";
    }

    function isOrganizer(challengeId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/challenges/$(challengeId)/participants/$(request.auth.uid))
          .data.isAdmin == true;
    }

    function isParticipant(challengeId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/challenges/$(challengeId)/participants/$(request.auth.uid));
    }

    // ── Invite codes (public) ─────────────────────────────────────────────
    // The invite doc holds only the name/emoji/description — no sensitive data.
    // Anyone with the code can read it to see the challenge onboarding screen.

    match /invites/{code} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── User profiles ──────────────────────────────────────────────────────

    match /users/{uid} {
      // Users can read and write only their own profile
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ── Challenges ─────────────────────────────────────────────────────────

    match /challenges/{challengeId} {
      // Any participant (or organizer) can read the challenge
      allow read: if isParticipant(challengeId);
      // Only owners can create or update the top-level challenge doc
      allow create: if isSignedIn();
      allow update: if isOrganizer(challengeId);
      allow delete: if isOwner(challengeId);

      // ── Participants subcollection ───────────────────────────────────────
      match /participants/{uid} {
        // Participants can read the full roster
        allow read: if isParticipant(challengeId);
        // Organizers can write (add/edit/remove participants)
        allow write: if isOrganizer(challengeId);
        // Allow a user to create their own participant doc when joining
        allow create: if isSignedIn() && request.auth.uid == uid;
      }

      // ── Feed subcollection ───────────────────────────────────────────────
      match /feed/{postId} {
        allow read: if isParticipant(challengeId);
        // Participants can create their own posts; organizers can update (approve/reject)
        allow create: if isParticipant(challengeId);
        allow update: if isOrganizer(challengeId) ||
          // Allow the post author to update likes/comments fields only
          (isParticipant(challengeId) &&
           request.resource.data.participantId == request.auth.uid);
        allow delete: if isOrganizer(challengeId);
      }

      // ── Submissions subcollection ────────────────────────────────────────
      match /submissions/{submissionId} {
        allow read: if isOrganizer(challengeId) ||
          // Participants can only read their own submissions
          resource.data.participantUid == request.auth.uid;
        allow create: if isParticipant(challengeId);
        // Only organizers can update status (approve/reject)
        allow update: if isOrganizer(challengeId);
        allow delete: if isOwner(challengeId);
      }

      // ── Penalties subcollection ──────────────────────────────────────────
      match /penalties/{penaltyId} {
        allow read: if isOrganizer(challengeId) ||
          resource.data.participantUid == request.auth.uid;
        allow create, update: if isOrganizer(challengeId);
        allow delete: if isOwner(challengeId);
      }

      // ── Achievements subcollection ───────────────────────────────────────
      match /achievements/{achievementId} {
        allow read: if isParticipant(challengeId);
        allow write: if isOrganizer(challengeId);
      }

      // ── Team subcollection ───────────────────────────────────────────────
      match /team/{memberId} {
        allow read: if isOrganizer(challengeId);
        allow write: if isOwner(challengeId);
      }

      // ── Tasks subcollection ──────────────────────────────────────────────
      match /tasks/{taskId} {
        allow read: if isParticipant(challengeId);
        allow write: if isOrganizer(challengeId);
      }

      // ── Task templates subcollection ─────────────────────────────────────
      match /taskTemplates/{templateId} {
        allow read: if isParticipant(challengeId);
        allow write: if isOrganizer(challengeId);
      }
    }
  }
}
