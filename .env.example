# Firebase project configuration
# Copy this file to .env and fill in your Firebase project values.
# All values are found in Firebase Console → Project Settings → Your apps → SDK setup.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: only needed if you use Firebase Analytics
# VITE_FIREBASE_MEASUREMENT_ID=

# Telegram Login Widget — the bot's public @username (without the @)
# Safe to expose client-side; it's just the username the widget renders under.
VITE_TELEGRAM_BOT_USERNAME=

# Strava API — numeric Client ID (safe to expose client-side; used only for the OAuth redirect URL)
# Client Secret is NOT stored here — set it via: firebase functions:secrets:set STRAVA_CLIENT_SECRET
VITE_STRAVA_CLIENT_ID=
