rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Submission proof photos
    // Write: only the participant may upload into their own folder,
    //        images under 15 MB. Path segments enforce uid ownership.
    // Read:  any authenticated user (needed for organiser review).
    match /challenges/{challengeId}/submissions/{userId}/{fileName} {
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 15 * 1024 * 1024;

      allow read: if request.auth != null;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
