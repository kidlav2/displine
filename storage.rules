rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Submission proof photos
    // Write: only the owner can upload into their own folder
    // Read:  any authenticated user who is a participant of that challenge
    match /challenges/{challengeId}/submissions/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;

      allow read: if request.auth != null &&
        firestore.exists(
          /databases/(default)/documents/challenges/$(challengeId)/participants/$(request.auth.uid)
        );
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
