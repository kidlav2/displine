rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Submission proof photos
    // Write: only the participant may upload into their own folder, and only
    //        images under 5 MB. Existence in the participants subcollection
    //        is required so removed participants cannot upload new files.
    // Read:  any authenticated participant of that challenge.
    match /challenges/{challengeId}/submissions/{userId}/{fileName} {
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 15 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*') &&
        firestore.exists(
          /databases/(default)/documents/challenges/$(challengeId)/participants/$(userId)
        );

      allow read: if request.auth != null &&
        firestore.exists(
          /databases/(default)/documents/challenges/$(challengeId)/participants/$(request.auth.uid)
        );
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
